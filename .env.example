# Copy to .env and fill in. The key lives ONLY on the server — never the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
PORT=8787
# Vision-capable Claude model
CLAUDE_MODEL=claude-sonnet-4-6

# Set to "1" to force the mock identifier even when a key is present (handy for UI work)
USE_MOCK=0
